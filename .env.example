# OpenRouter API key (required for live AI mode)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# You can override model if needed
# Recommended balanced default for this MVP:
OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional: dedicated model for unified AI decision pipeline
OPENROUTER_MODEL_DECISION=google/gemini-2.5-flash
# Optional: separate model for Telegram replies (can be faster/cheaper)
OPENROUTER_MODEL_TELEGRAM=google/gemini-2.5-flash
AI_DECISION_TIMEOUT_MS=9000
AI_DECISION_RETRIES=2
AI_AUTO_REPLY_ENABLED=true

# Required for OpenRouter headers.
# Local dev:
# OPENROUTER_SITE_URL=http://localhost:5173
# Vercel production:
OPENROUTER_SITE_URL=https://your-domain.com

# Durable server storage (Supabase Postgres)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Runtime context guard
# Production path never auto-falls back to demo context.
# In local dev you can keep this true for quick smoke tests without auth bootstrap.
CFLOW_ALLOW_DEMO_CONTEXT=false

# Dev-only auth bypass (must stay false in production)
CFLOW_ALLOW_DEV_AUTH_BYPASS=false

# Frontend-only equivalent for local dashboard bootstrap.
VITE_ALLOW_DEMO_CONTEXT=false

# Follow-up engine
# Provider: local | qstash
FOLLOW_UP_PROVIDER=local
FOLLOW_UP_NO_RESPONSE_HOURS=6
FOLLOW_UP_PRICE_GHOST_HOURS=2
FOLLOW_UP_NOT_BOOKED_HOURS=24
FOLLOW_UP_MAX_RETRIES=3

# Required only for FOLLOW_UP_PROVIDER=qstash
QSTASH_TOKEN=
FOLLOW_UP_EXECUTE_URL=https://your-domain.com/api/followup/execute

# Unified ingestion forwarding / Instagram webhook verification
APP_BASE_URL=https://your-domain.com
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=dev_verify_token

# VK callback / long-poll prototype
VK_CONFIRMATION_TOKEN=dev_vk_confirmation_token

# Internal deferred dispatch / cron auth token.
# On Vercel Cron requests, Authorization: Bearer <CRON_SECRET> is used automatically.
CRON_SECRET=replace_with_long_random_value
# Optional explicit token for internal dispatch calls (if empty, CRON_SECRET is used).
CFLOW_INTERNAL_DISPATCH_TOKEN=
# Enable non-blocking deferred dispatch path for heavy ops actions (recommended for production).
CFLOW_ENABLE_DEFERRED_DISPATCH=true

# Generic CRM webhook handoff
CRM_WEBHOOK_URL=
CRM_WEBHOOK_TOKEN=
CRM_WEBHOOK_TIMEOUT_MS=12000
CRM_HANDOFF_MAX_RETRIES=3
# Keep false for reliability (enqueue now, dispatch separately via /api/crm/handoff).
CRM_HANDOFF_INLINE_EXECUTION=false

# Channel connection manager
# If set, tokens are obfuscated/encrypted for storage in channel_connections.encrypted_access_token
CHANNEL_TOKEN_SECRET=
# In local prototype mode, allow plaintext fallback in access_token for runtime calls.
CHANNEL_ALLOW_DEV_PLAINTEXT_TOKEN=true

# Billing provider layer
# mock (default) | stripe_stub
BILLING_PROVIDER=mock

# Stripe preparation (not used for real payments yet)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FREE=price_mock_free
STRIPE_PRICE_ID_PRO=price_mock_pro
STRIPE_PRICE_ID_ENTERPRISE=price_mock_enterprise
