# OpenRouter API key (required for live AI mode)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# You can override model if needed
# Recommended balanced default for this MVP:
OPENROUTER_MODEL=google/gemini-2.5-pro

# Required for OpenRouter headers.
# Local dev:
# OPENROUTER_SITE_URL=http://localhost:5173
# Vercel production:
OPENROUTER_SITE_URL=https://clients-flow-ten.vercel.app
